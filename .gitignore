# Smart Energy Grid — .gitignore:
# ===============================

# Environment variables:
.env

# AWS IoT TLS certificates:
certs/

# Safety net — catch any stray cert/key files outside certs/:
*.pem
*.key
*.crt

# Infrastructure provisioning script:
backend/infra/deploy.sh

# Lambda deployment ZIPs:
backend/lambda/*.zip

# Virtual environments:
.venv/
venv/
env/
.env.example

# Compiled bytecode:
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.egg-info/
dist/
build/
.eggs/

# pytest cache:
.pytest_cache/
.mypy_cache/

# IDE — IntelliJ IDEA:
.idea/
*.iml
.claude/
.DS_Store
.AppleDouble
.LSOverride

# Docker volume data:
mosquitto_data/
mosquitto_log/

# Logs
*.log
logs/
.ec2_instance