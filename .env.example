# Copy this file to .env and fill in your actual values.
# Never commit the real .env file — it contains secrets.
# The .env file is already in .gitignore.

# --- MQTT Broker (local fog node or cloud broker) ---
# This is the address of the MQTT broker the sensors publish to.
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# --- AWS IoT Core (for cloud connectivity from the fog node) ---
# The endpoint is unique to your AWS account — find it in the IoT Core console.
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com

# Paths to the certificate files downloaded from AWS IoT Core when you created a Thing.
# These are needed to authenticate the fog node with AWS.
AWS_IOT_CERT_PATH=certs/device-certificate.pem.crt
AWS_IOT_KEY_PATH=certs/private.pem.key
AWS_IOT_CA_PATH=certs/AmazonRootCA1.pem

# --- AWS General ---
AWS_REGION=us-east-1

# --- DynamoDB ---
# The name of the table where sensor readings get stored.
DYNAMODB_TABLE_NAME=smart-energy-readings
