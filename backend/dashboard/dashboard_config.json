{
  "__inputs": [
    {
      "name": "DS_INFINITY",
      "label": "Infinity Datasource",
      "description": "Select the Infinity datasource you created pointing at the query_handler Lambda URL",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "pluginName": "Infinity"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "yesoreyeram-infinity-datasource",
      "name": "Infinity",
      "version": "2.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],

  "title": "Smart Energy Grid — Fog & Edge Computing",
  "description": "Live sensor dashboard for the NCI Smart Energy Grid IoT project. Shows solar, grid, battery, EV and temperature data across 3 homes.",
  "uid": "smart-energy-grid-v1",
  "schemaVersion": 38,
  "version": 1,
  "revision": 1,
  "refresh": "30s",
  "tags": ["energy", "iot", "fog-computing", "nci"],
  "timezone": "browser",
  "graphTooltip": 1,

  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["15s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "3h", "6h", "12h", "24h"]
  },

  "templating": {
    "list": [
      {
        "name": "lambda_url",
        "type": "textbox",
        "label": "Lambda Function URL",
        "description": "Paste your query_handler Lambda Function URL here (from AWS Console → Lambda → Function URL)",
        "current": {
          "value": "https://your-lambda-id.lambda-url.eu-west-1.on.aws"
        },
        "query": "https://your-lambda-id.lambda-url.eu-west-1.on.aws",
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "hours",
        "type": "custom",
        "label": "Time Window (hours)",
        "description": "How many hours of data to load from the API",
        "current": {"text": "1", "value": "1"},
        "options": [
          {"selected": true,  "text": "1h",  "value": "1"},
          {"selected": false, "text": "3h",  "value": "3"},
          {"selected": false, "text": "6h",  "value": "6"},
          {"selected": false, "text": "12h", "value": "12"},
          {"selected": false, "text": "24h", "value": "24"}
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "Solar Output (kW)",
      "description": "Power generated by solar panels across all 3 homes. Peaks at noon, zero at night.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "kwatt",
          "decimals": 2,
          "min": 0,
          "max": 5
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Home-1"}, "properties": [{"id": "color", "value": {"fixedColor": "#73BF69", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-2"}, "properties": [{"id": "color", "value": {"fixedColor": "#56A64B", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-3"}, "properties": [{"id": "color", "value": {"fixedColor": "#37872D", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json",
          "source": "url",
          "url": "${lambda_url}?home_id=home_1&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time", "type": "timestamp"},
            {"selector": "solar_avg",  "text": "Home-1", "type": "number"}
          ]
        },
        {
          "refId": "B",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json",
          "source": "url",
          "url": "${lambda_url}?home_id=home_2&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time", "type": "timestamp"},
            {"selector": "solar_avg",  "text": "Home-2", "type": "number"}
          ]
        },
        {
          "refId": "C",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json",
          "source": "url",
          "url": "${lambda_url}?home_id=home_3&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time", "type": "timestamp"},
            {"selector": "solar_avg",  "text": "Home-3", "type": "number"}
          ]
        }
      ]
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Grid Consumption (kW)",
      "description": "Power imported from the electricity grid. Morning and evening peaks are normal.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "kwatt",
          "decimals": 2,
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Home-1"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-2"}, "properties": [{"id": "color", "value": {"fixedColor": "#C4162A", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-3"}, "properties": [{"id": "color", "value": {"fixedColor": "#8F1F2E", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_1&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "grid_avg",  "text": "Home-1", "type": "number"}
          ]
        },
        {
          "refId": "B",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_2&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "grid_avg",  "text": "Home-2", "type": "number"}
          ]
        },
        {
          "refId": "C",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_3&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "grid_avg",  "text": "Home-3", "type": "number"}
          ]
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Battery Level (%)",
      "description": "State of charge for the home battery. Charges during daylight, discharges overnight. Alert fires below 15%.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 15},
              {"color": "green",  "value": 30}
            ]
          }
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Home-1"}, "properties": [{"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-2"}, "properties": [{"id": "color", "value": {"fixedColor": "#3274D9", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-3"}, "properties": [{"id": "color", "value": {"fixedColor": "#1F60C4", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_1&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",   "text": "Time",   "type": "timestamp"},
            {"selector": "battery_avg", "text": "Home-1", "type": "number"}
          ]
        },
        {
          "refId": "B",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_2&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",   "text": "Time",   "type": "timestamp"},
            {"selector": "battery_avg", "text": "Home-2", "type": "number"}
          ]
        },
        {
          "refId": "C",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_3&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",   "text": "Time",   "type": "timestamp"},
            {"selector": "battery_avg", "text": "Home-3", "type": "number"}
          ]
        }
      ]
    },

    {
      "id": 4,
      "type": "barchart",
      "title": "EV Charger State (kW)",
      "description": "Either 0 kW (idle) or 7.4 kW (charging session active). Bar chart suits the on/off nature better than a line.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "unit": "kwatt",
          "decimals": 1,
          "min": 0,
          "max": 8
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Home-1"}, "properties": [{"id": "color", "value": {"fixedColor": "#FADE2A", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-2"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2CC0C", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-3"}, "properties": [{"id": "color", "value": {"fixedColor": "#E0B400", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "xField": "Time"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_1&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "ev_avg",    "text": "Home-1", "type": "number"}
          ]
        },
        {
          "refId": "B",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_2&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "ev_avg",    "text": "Home-2", "type": "number"}
          ]
        },
        {
          "refId": "C",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_3&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp", "text": "Time",   "type": "timestamp"},
            {"selector": "ev_avg",    "text": "Home-3", "type": "number"}
          ]
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Indoor Temperature (°C)",
      "description": "Simulated smart thermostat readings. Temperature drifts toward schedule targets — 17°C night, 21°C morning/evening, 19°C daytime.",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6,
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "celsius",
          "decimals": 1,
          "min": 15,
          "max": 25
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Home-1"}, "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-2"}, "properties": [{"id": "color", "value": {"fixedColor": "#E36F00", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Home-3"}, "properties": [{"id": "color", "value": {"fixedColor": "#C45300", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_1&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",       "text": "Time",   "type": "timestamp"},
            {"selector": "temperature_avg", "text": "Home-1", "type": "number"}
          ]
        },
        {
          "refId": "B",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_2&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",       "text": "Time",   "type": "timestamp"},
            {"selector": "temperature_avg", "text": "Home-2", "type": "number"}
          ]
        },
        {
          "refId": "C",
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}"},
          "type": "json", "source": "url",
          "url": "${lambda_url}?home_id=home_3&hours=${hours}",
          "url_options": {"method": "GET", "headers": []},
          "root_selector": "readings",
          "columns": [
            {"selector": "timestamp",       "text": "Time",   "type": "timestamp"},
            {"selector": "temperature_avg", "text": "Home-3", "type": "number"}
          ]
        }
      ]
    }

  ]
}
